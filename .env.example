# VERIDIS MEDIA — variables de entorno
# Copia este archivo a .env.local y rellena los valores.

# Webhook de LeadConnector / GoHighLevel que dispara la automatización "EN VIVO".
LIVE_WEBHOOK_URL=

# Secreto opcional para proteger /api/live/go-live.
# Si lo defines, las llamadas deben incluir el header `x-veridis-secret` (o ?secret=).
LIVE_WEBHOOK_SECRET=

# URL pública del sitio (para construir watch_url/event_url en el payload).
NEXT_PUBLIC_SITE_URL=https://veridismedia.com

# Panel de admin (/admin)
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Estado en tiempo real (Vercel KV). En local, vacío = fallback en memoria.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Cloudflare Stream (ingesta RTMP + auto-detección de LIVE)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_SUBDOMAIN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_LIVE_INPUT_UID=
CLOUDFLARE_STREAM_KEY=
CLOUDFLARE_RTMPS_URL=rtmps://live.cloudflare.com:443/live/
CLOUDFLARE_WEBHOOK_SECRET=
